# ═══════════════════════════════════════════════════════
#  AI Face Analyzer — Netlify Environment Variables
#  Netlify Dashboard → Site → Environment Variables mein add karo
#  NEVER commit real values to git!
# ═══════════════════════════════════════════════════════

# ── RAZORPAY ──────────────────────────────────────────
RAZORPAY_KEY_ID=YOUR_RAZORPAY_LIVE_KEY
RAZORPAY_KEY_SECRET=YOUR_NEW_SECRET_HERE

# ── FIREBASE ADMIN SDK ────────────────────────────────
# Firebase Console → Project Settings → Service Accounts
# → Generate new private key → Download JSON
# → Entire JSON as ONE LINE (no newlines)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_FIREBASE_PROJECT_ID","private_key_id":"YOUR_KEY_ID","private_key":"-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk@yash-software.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

FIREBASE_DATABASE_URL=https://yash-software-default-rtdb.firebaseio.com
